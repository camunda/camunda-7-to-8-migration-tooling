<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_jobPriorityUnsupported" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.31.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.22.0">
  <bpmn:process id="JobPriorityUnsupportedProcess" name="JobPriorityUnsupportedProcess" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_StartToDmn</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:subProcess id="SubProc" camunda:asyncBefore="true" camunda:jobPriority="150">
      <bpmn:incoming>Flow_ParallelGwToSubProc</bpmn:incoming>
      <bpmn:outgoing>Flow_SubProcToParallelJoin</bpmn:outgoing>
      <bpmn:outgoing>Flow_SubProcToThrow</bpmn:outgoing>
      <bpmn:startEvent id="SubProcStart" camunda:asyncAfter="true" camunda:jobPriority="177">
        <bpmn:outgoing>Flow_SubProcStartToFeel</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:endEvent id="SubProcEnd" camunda:asyncBefore="true" camunda:jobPriority="32">
        <bpmn:incoming>Flow_FeelToSubProcEnd</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_SubProcStartToFeel" sourceRef="SubProcStart" targetRef="FeelTask" />
      <bpmn:sequenceFlow id="Flow_FeelToSubProcEnd" sourceRef="FeelTask" targetRef="SubProcEnd" />
      <bpmn:scriptTask id="FeelTask" camunda:asyncBefore="true" camunda:jobPriority="160" scriptFormat="Feel" camunda:resultVariable="sumVal">
        <bpmn:incoming>Flow_SubProcStartToFeel</bpmn:incoming>
        <bpmn:outgoing>Flow_FeelToSubProcEnd</bpmn:outgoing>
        <bpmn:script>1 + 1</bpmn:script>
      </bpmn:scriptTask>
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_StartToDmn" sourceRef="StartEvent_1" targetRef="DmnTask" />
    <bpmn:sequenceFlow id="Flow_DmnToParallelGw" sourceRef="DmnTask" targetRef="ParallelGw" />
    <bpmn:sequenceFlow id="Flow_ParallelGwToSubProc" sourceRef="ParallelGw" targetRef="SubProc" />
    <bpmn:parallelGateway id="ParallelGw" camunda:asyncBefore="true" camunda:jobPriority="12">
      <bpmn:incoming>Flow_DmnToParallelGw</bpmn:incoming>
      <bpmn:outgoing>Flow_ParallelGwToSubProc</bpmn:outgoing>
      <bpmn:outgoing>Flow_ParallelGwToReviewer</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_ParallelGwToReviewer" sourceRef="ParallelGw" targetRef="Reviewer" />
    <bpmn:parallelGateway id="ParallelJoin">
      <bpmn:incoming>Flow_ReviewerToParallelJoin</bpmn:incoming>
      <bpmn:incoming>Flow_SubProcToParallelJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_ParallelJoinToEnd</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_ReviewerToParallelJoin" sourceRef="Reviewer" targetRef="ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_SubProcToParallelJoin" sourceRef="SubProc" targetRef="ParallelJoin" />
    <bpmn:endEvent id="EndEvent_1">
      <bpmn:incoming>Flow_ParallelJoinToEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ParallelJoinToEnd" sourceRef="ParallelJoin" targetRef="EndEvent_1" />
    <bpmn:businessRuleTask id="DmnTask" camunda:asyncBefore="true" camunda:jobPriority="15" camunda:resultVariable="result" camunda:decisionRef="dmnTask" camunda:mapDecisionResult="singleEntry">
      <bpmn:incoming>Flow_StartToDmn</bpmn:incoming>
      <bpmn:outgoing>Flow_DmnToParallelGw</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:intermediateThrowEvent id="Throw">
      <bpmn:incoming>Flow_SubProcToThrow</bpmn:incoming>
    </bpmn:intermediateThrowEvent>
    <bpmn:sequenceFlow id="Flow_SubProcToThrow" sourceRef="SubProc" targetRef="Throw" />
    <bpmn:boundaryEvent id="BoundaryEvt" camunda:asyncBefore="true" camunda:jobPriority="43" attachedToRef="SubProc" />
    <bpmn:userTask id="Reviewer" camunda:asyncAfter="true" camunda:jobPriority="5">
      <bpmn:incoming>Flow_ParallelGwToReviewer</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewerToParallelJoin</bpmn:outgoing>
    </bpmn:userTask>
  </bpmn:process>
