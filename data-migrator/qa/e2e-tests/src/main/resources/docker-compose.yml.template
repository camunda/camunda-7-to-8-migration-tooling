services:
  # Camunda 7 with Cockpit plugin
  camunda7:
    image: registry.camunda.cloud/cambpm-ee/camunda-bpm-platform-ee:7.24.1
    user: root
    ports:
      - "8090:8080"
    environment:
      - DB_DRIVER=org.postgresql.Driver
      - DB_URL=jdbc:postgresql://postgres:5432/camunda
      - DB_USERNAME=camunda
      - DB_PASSWORD=camunda
      - WAIT_FOR=postgres:5432
    volumes:
      # Mount the plugin JAR to Camunda's plugin directory
      - ../../plugins/cockpit/target/camunda-7-to-8-data-migrator-cockpit-plugin-${project.version}.jar:/camunda/webapps/camunda/WEB-INF/lib/camunda-7-to-8-data-migrator-cockpit-plugin.jar:ro
      # Mount custom Cockpit config with operateUrl
      - ./src/main/resources/cockpit-config.js:/camunda/webapps/camunda/app/cockpit/scripts/config.js:ro
    command:
      - /bin/sh
      - -c
      - |
        set -e
        echo 'Installing JDK 21...'
        apk add --no-cache openjdk21
        export JAVA_HOME=/usr/lib/jvm/java-21-openjdk
        export PATH=$$JAVA_HOME/bin:$$PATH
        echo 'JDK 21 installed successfully'
        java -version
        echo 'Starting Camunda...'
        exec /camunda/camunda.sh
    depends_on:
      postgres:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/camunda/app/cockpit/default/"]
      interval: 10s
      timeout: 5s
      retries: 30
      start_period: 60s
    networks:
      - e2e-network

  # PostgreSQL for Camunda 7
  postgres:
    image: postgres:18
    environment:
      - POSTGRES_DB=camunda
      - POSTGRES_USER=camunda
      - POSTGRES_PASSWORD=camunda
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U camunda -d camunda"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - e2e-network

  # Data Migrator - runs migration to generate test data
  data-migrator:
    image: eclipse-temurin:21-jdk
    volumes:
      - ../../assembly/target/camunda-7-to-8-data-migrator-${project.version}.zip:/tmp/migrator.zip:ro
      - ./src/main/resources/invoice-example:/app/configuration/resources/invoice:ro
      - ./src/main/resources/process-example-c8:/app/configuration/resources/process:ro
      - ./src/main/resources/process-example:/tmp/c7-bpmns:ro
    working_dir: /app
    environment:
      - CAMUNDA_MIGRATOR_C7_DATA_SOURCE_JDBC_URL=jdbc:postgresql://postgres:5432/camunda
      - CAMUNDA_MIGRATOR_C7_DATA_SOURCE_USERNAME=camunda
      - CAMUNDA_MIGRATOR_C7_DATA_SOURCE_PASSWORD=camunda
      - CAMUNDA_MIGRATOR_C7_DATA_SOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
      - CAMUNDA_MIGRATOR_C8_DATA_SOURCE_JDBC_URL=jdbc:postgresql://postgres:5432/camunda
      - CAMUNDA_MIGRATOR_C8_DATA_SOURCE_USERNAME=camunda
      - CAMUNDA_MIGRATOR_C8_DATA_SOURCE_PASSWORD=camunda
      - CAMUNDA_MIGRATOR_C8_DATA_SOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
      - CAMUNDA_MIGRATOR_AUTO_DDL=true
      - CAMUNDA_MIGRATOR_SAVE_SKIP_REASON=true
      - CAMUNDA_CLIENT_MODE=self-managed
      - CAMUNDA_CLIENT_GRPC_ADDRESS=http://camunda8:26500
      - CAMUNDA_CLIENT_REST_ADDRESS=http://camunda8:8080
    command:
      - /bin/bash
      - -c
      - |
        set -e
        echo 'Extracting migrator distribution...'
        apt-get update -qq && apt-get install -y -qq unzip wget curl jq > /dev/null
        unzip -q /tmp/migrator.zip -d /app
        echo 'Downloading PostgreSQL driver...'
        wget -q https://jdbc.postgresql.org/download/postgresql-42.7.3.jar -O /app/configuration/userlib/postgresql.jar
        echo 'Deploying C7 process BPMNs via REST API...'
        C7_REST=http://camunda7:8080/engine-rest

        # Wait for C7 REST API to be ready
        echo 'Waiting for C7 REST API...'
        for i in $$(seq 1 30); do
          if curl -sf --connect-timeout 5 --max-time 10 "$$C7_REST/engine" > /dev/null 2>&1; then
            echo "C7 REST API is ready"
            break
          fi
          echo "Attempt $$i: C7 REST API not ready yet..."
          sleep 3
        done

        # Deploy BPMNs via REST API
        echo "Deploying BPMNs from /tmp/c7-bpmns/..."
        ls -la /tmp/c7-bpmns/
        HTTP_CODE=$$(curl -s -o /tmp/deploy-response.json -w "%{http_code}" --max-time 30 -X POST "$$C7_REST/deployment/create" \
          -F "deployment-name=process-example" \
          -F "enable-duplicate-filtering=false" \
          -F "callActivityProcess.bpmn=@/tmp/c7-bpmns/callActivityProcess.bpmn" \
          -F "miProcess-subprocess.bpmn=@/tmp/c7-bpmns/miProcess-subprocess.bpmn")
        echo "Deployment response (HTTP $$HTTP_CODE): $$(cat /tmp/deploy-response.json)"
        if [ "$$HTTP_CODE" -lt 200 ] || [ "$$HTTP_CODE" -ge 300 ]; then
          echo "ERROR: BPMN deployment failed with HTTP $$HTTP_CODE" >&2
          exit 1
        fi

        # Start callingProcessId with typed variables
        echo "Starting callingProcessId..."
        HTTP_CODE=$$(curl -s -o /tmp/start-response.json -w "%{http_code}" --max-time 30 -X POST "$$C7_REST/process-definition/key/callingProcessId/start" \
          -H "Content-Type: application/json" \
          -d '{
            "variables": {
              "stringVar": {"value": "hello world", "type": "String"},
              "intVar": {"value": 42, "type": "Integer"},
              "boolVar": {"value": true, "type": "Boolean"},
              "doubleVar": {"value": 3.14, "type": "Double"},
              "longVar": {"value": 9999999, "type": "Long"}
            }
          }')
        echo "Start response (HTTP $$HTTP_CODE): $$(cat /tmp/start-response.json)"
        if [ "$$HTTP_CODE" -lt 200 ] || [ "$$HTTP_CODE" -ge 300 ]; then
          echo "ERROR: Process start failed with HTTP $$HTTP_CODE" >&2
          exit 1
        fi

        # C7's job executor automatically processes async-before jobs, so we
        # just need to wait for user tasks to appear and then complete them.

        # Poll & complete user tasks (parallel MI, cardinality=3 — all 3 exist at once)
        echo "Waiting for user tasks to appear (C7 job executor handles async-before automatically)..."
        COUNTER=1
        TASKS_FOUND=false
        for i in $$(seq 1 30); do
          TASKS=$$(curl -sf --max-time 10 "$$C7_REST/task?processDefinitionKey=miProcess" 2>/dev/null) || TASKS="[]"
          TASK_COUNT=$$(echo "$$TASKS" | jq 'length' 2>/dev/null || echo "0")
          echo "Tasks found (attempt $$i): $$TASK_COUNT"
          if [ "$$TASK_COUNT" -gt "0" ]; then
            TASK_IDS=$$(echo "$$TASKS" | jq -r '.[].id' 2>/dev/null)
            for TASK_ID in $$TASK_IDS; do
              HTTP_CODE=$$(curl -s -o /tmp/task-complete-response.json -w "%{http_code}" --max-time 10 \
                -X POST "$$C7_REST/task/$$TASK_ID/complete" \
                -H "Content-Type: application/json" \
                -d "{\"variables\": {\"taskResult\": {\"value\": \"result-$$COUNTER\", \"type\": \"String\"}}}")
              if [ "$$HTTP_CODE" -lt 200 ] || [ "$$HTTP_CODE" -ge 300 ]; then
                echo "ERROR: Task completion failed for $$TASK_ID with HTTP $$HTTP_CODE" >&2
                exit 1
              fi
              echo "Completed task $$COUNTER/3: $$TASK_ID (HTTP $$HTTP_CODE)"
              COUNTER=$$((COUNTER + 1))
            done
            TASKS_FOUND=true
            break
          fi
          sleep 2
        done
        if [ "$$TASKS_FOUND" = "false" ]; then
          echo "ERROR: No user tasks found after 30 attempts" >&2
          exit 1
        fi

        # The failingTask (async-before service task with class "no-op") will be
        # automatically executed by C7's job executor and fail, creating an incident.
        echo "Waiting for failingTask incident to be created by C7 job executor..."
        INCIDENT_FOUND=false
        for i in $$(seq 1 15); do
          INCIDENTS=$$(curl -sf --max-time 10 "$$C7_REST/incident?processDefinitionKey=miProcess" 2>/dev/null) || INCIDENTS="[]"
          INCIDENT_COUNT=$$(echo "$$INCIDENTS" | jq 'length' 2>/dev/null || echo "0")
          echo "Incidents found (attempt $$i): $$INCIDENT_COUNT"
          if [ "$$INCIDENT_COUNT" -gt "0" ]; then
            INCIDENT_FOUND=true
            echo "Incident created for failingTask"
            break
          fi
          sleep 2
        done
        if [ "$$INCIDENT_FOUND" = "false" ]; then
          echo "WARNING: No incident found for failingTask — the job executor may not have processed it yet. Continuing anyway."
        fi

        echo 'C7 process instances created.'

        echo 'Starting data migration...'
        cd /app
        ./start.sh --history
        echo 'Waiting 5 seconds for deployments to become available in Operate...'
        sleep 5
        ./start.sh --runtime
        echo 'Migration completed - test data ready'
    depends_on:
      camunda7:
        condition: service_healthy
      camunda8:
        condition: service_healthy
    networks:
      - e2e-network

  camunda8: # Consolidated Zeebe + Operate + Tasklist - https://docs.camunda.io/docs/self-managed/setup/deploy/other/docker/#zeebe
    image: ${camunda8.docker.image}
    container_name: camunda8
    ports:
      - "26500:26500"
      - "9600:9600"
      - "8088:8080"
    restart: always
    healthcheck:
      test: [ "CMD-SHELL", "bash -c 'exec 3<>/dev/tcp/127.0.0.1/9600 && echo -e \"GET /actuator/health/status HTTP/1.1\r\nHost: localhost\r\n\r\n\" >&3 && head -n 1 <&3'" ]
      interval: 1s
      retries: 30
      start_period: 30s
    volumes:
      - zeebe:/usr/local/zeebe/data
    configs:
      - source: camunda8-config
        target: /usr/local/camunda/config/application.yaml
    networks:
      - e2e-network

configs:
  camunda8-config:
    content: |
      management.endpoints.configprops.show-values: always
      zeebe.broker.exporters.rdbms.classname: io.camunda.exporter.rdbms.RdbmsExporter
      camunda:
        system:
          cpu-thread-count: "3"
          io-thread-count: "3"
        security:
          authentication:
            method: "basic"
            unprotectedApi: true
          authorizations:
            enabled: false
          initialization:
            users:
              - username: "demo"
                password: "demo"
                name: "Demo User"
                email: "demo@demo.com"
            defaultRoles.admin.users:
              - "demo"
        data:
          secondary-storage:
            type: rdbms
            rdbms:
              database-vendor-id: "postgresql"
              url: "jdbc:postgresql://postgres:5432/camunda"
              username: "camunda"
              password: "camunda"

volumes:
  zeebe:

networks:
  e2e-network:
    driver: bridge
